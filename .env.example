# .env.example
# 复制为 .env (本地) 或通过 supabase secrets set 设置 (云端)
# ⚠️ 真实密钥绝不入仓 (.gitignore 已屏蔽 .env)

# ===== Supabase =====
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...                  # Dashboard → Project Settings → API
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...          # 仅服务端 Edge Function 用 (admin)

# ===== LLM 切换 (Phase 1 试用: FreeLLMAPI / Phase 2 正式: DeepSeek) =====
# 14.6.1 硬开关: isPublicRelease=true 时必须切到付费 API
LLM_PROVIDER=freellmapi                          # 'freellmapi' | 'deepseek' | 'groq' | 'openai'
IS_PUBLIC_RELEASE=false                          # false=FreeLLMAPI 仅自测; true=强制走付费

# ----- Phase 1: FreeLLMAPI -----
FREELLMAPI_URL=http://localhost:3001/v1          # 本地/私有网络
FREELLMAPI_KEY=freellmapi-xxx

# ----- Phase 2: DeepSeek -----
DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# ===== AdMob (Week 6+ 启用) =====
ADMOB_APP_ID_WEB=ca-app-pub-XXX
ADMOB_BANNER_ID=ca-app-pub-XXX/YYY
ADMOB_REWARDED_ID=ca-app-pub-XXX/ZZZ

# ===== RevenueCat (Week 10+ iOS/Android) =====
REVENUECAT_PUBLIC_KEY=appl_xxx
REVENUECAT_ENTITLEMENT=premium
