# interpret Edge Function — server-side secrets
#
# NOTE: these go into Supabase Edge Function secrets via:
#   supabase secrets set LLM_BASE_URL=... LLM_API_KEY=... LLM_MODEL=... --project-ref xjvoqpijrpjmgqkqwhqd
# NOT in source / NOT in GitHub.

# === 推荐配置: 通用三件套 (适配任何 OpenAI 兼容 API) ===
# DeepSeek (当前选定的 provider, 2026-07-03 线上验证通过):
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=replace_me_or_set_via_supabase_secrets
LLM_MODEL_BRIEF=deepseek-v4-flash
LLM_MODEL_DETAILED=deepseek-v4-pro
# 备注: DeepSeek v4 的思考过程在单独的 reasoning_content 字段, content 干净;
#       MiniMax M 系列则内联 <think> 块 (index.ts 已做剥离, 两家都兼容).

# 可选: 不分层时用单一模型 (优先级低于 LLM_MODEL_BRIEF/DETAILED)
# LLM_MODEL=

# 其他 provider 示例 (已实测可用):
#   MiniMax:    LLM_BASE_URL=https://api.minimaxi.com/v1
#               LLM_MODEL_BRIEF=MiniMax-M2.7-highspeed  LLM_MODEL_DETAILED=MiniMax-M3
#   FreeLLMAPI: LLM_BASE_URL=http://localhost:3001/v1   LLM_MODEL 留空走内置路由表
#               (仅本地自测; 云端 Edge Function 连不上 localhost)

# === 兼容旧变量 (仍可用, 优先级低于 LLM_*) ===
# FREELLMAPI_URL=http://localhost:3001/v1
# FREELLMAPI_KEY=
# DEEPSEEK_API_KEY=

# Set "true" ONLY when frontend is accessible to non-owner users.
# In public-release mode the function blocks requests that still point to localhost.
IS_PUBLIC_RELEASE=false
