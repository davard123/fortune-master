# interpret Edge Function — server-side secrets
# Local dev (FreeLLMAPI self-hosted, MIT-licensed multi-provider router)
#   https://github.com/tashfeenahmed/freellmapi
#
# NOTE: these go into Supabase Edge Function secrets via:
#   supabase secrets set FREELLMAPI_URL=...  FREELLMAPI_KEY=...  IS_PUBLIC_RELEASE=false --project-ref xjvoqpijrpjmgqkqwhqd
# NOT in source / NOT in GitHub.

# OpenAI-compatible endpoint, e.g. http://localhost:3001/v1 for local Docker
FREELLMAPI_URL=http://localhost:3001/v1

# API key matching the FREELLMAPI_URL provider (formats vary by upstream).
# DO NOT commit a real key here.
FREELLMAPI_KEY=replace_me_or_set_via_supabase_secrets

# Set "true" ONLY when frontend is accessible to non-owner users.
# In public-release mode the function blocks requests that still point to localhost.
IS_PUBLIC_RELEASE=false

# === Phase 2 (production) swap ===
# Set LLM_BASE_URL=https://api.deepseek.com/v1 and LLM_API_KEY=<deepseek-key>
# to bypass FreeLLMAPI and use DeepSeek directly. No business-code changes needed.
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_API_KEY=
